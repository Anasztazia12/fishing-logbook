rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Images are stored at: {userId}/{catchId}/{filename}
    // Each user can only access files under their own userId folder
    match /{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
